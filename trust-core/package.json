{
  "name": "@realreel/c2pa-trust-core",
  "version": "0.3.0",
  "description": "Part of the open-source RealReel C2PA signing/verification stack — shapes, trust list, action allowlists, and pure policy functions (no I/O, no native deps, no crypto). Shared between the RealReel client preflight gate and the Cloud Run verifier.",
  "keywords": [
    "c2pa",
    "content-credentials",
    "content-authenticity",
    "provenance",
    "trust-list",
    "realreel"
  ],
  "license": "Apache-2.0",
  "author": "Whole Earth Labs LLC",
  "homepage": "https://github.com/wholeearthlabs/realreel-c2pa/tree/main/trust-core#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wholeearthlabs/realreel-c2pa.git",
    "directory": "trust-core"
  },
  "bugs": {
    "url": "https://github.com/wholeearthlabs/realreel-c2pa/issues"
  },
  "type": "module",
  "sideEffects": false,
  "//": "Dual-format because jest (jest-expo, CommonJS) doesn't transform node_modules ESM, so the closed app needs a CommonJS build (resolved via `require` → dist/commonjs); ESM consumers like the verifier (NodeNext) get dist/esm via `import`. The in-repo verifier consumes these entry points, so dist/ must be built before it resolves: `prepare` builds on install, and the root `test` rebuilds first. dist/ is gitignored — regenerated, never committed.",
  "main": "./dist/commonjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/commonjs/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/commonjs/index.d.ts",
        "default": "./dist/commonjs/index.js"
      }
    },
    "./shapes": {
      "import": {
        "types": "./dist/esm/shapes/index.d.ts",
        "default": "./dist/esm/shapes/index.js"
      },
      "require": {
        "types": "./dist/commonjs/shapes/index.d.ts",
        "default": "./dist/commonjs/shapes/index.js"
      }
    },
    "./errors": {
      "import": {
        "types": "./dist/esm/errors/index.d.ts",
        "default": "./dist/esm/errors/index.js"
      },
      "require": {
        "types": "./dist/commonjs/errors/index.d.ts",
        "default": "./dist/commonjs/errors/index.js"
      }
    },
    "./policies": {
      "import": {
        "types": "./dist/esm/policies/index.d.ts",
        "default": "./dist/esm/policies/index.js"
      },
      "require": {
        "types": "./dist/commonjs/policies/index.d.ts",
        "default": "./dist/commonjs/policies/index.js"
      }
    },
    "./trust-list": {
      "import": {
        "types": "./dist/esm/trust-list/index.d.ts",
        "default": "./dist/esm/trust-list/index.js"
      },
      "require": {
        "types": "./dist/commonjs/trust-list/index.d.ts",
        "default": "./dist/commonjs/trust-list/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.cjs.json && tsc -p tsconfig.esm.json && node scripts/finalize-build.mjs",
    "prepare": "npm run build",
    "test": "vitest run",
    "verify:dual-format": "node scripts/verify-dual-format.mjs"
  },
  "devDependencies": {
    "typescript": "~5.9.2",
    "vitest": "^2.0.0"
  }
}
