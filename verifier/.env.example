# Template for verifier env vars. Reference for production deployments
# (Cloud Run env block) and OSS extraction. This file is committed; the
# values here are placeholders, not real secrets.
#
# Local dev DOES NOT load this file — `make verifier-dev` sets env vars
# inline in the Makefile target. See the Makefile's `verifier-dev` block
# for the local-dev defaults. This file exists for two consumers:
#   1. Production deployments — copy these names into Cloud Run env
#      configuration; fill values from the corresponding sources noted
#      below. Full deploy playbook in verifier/DEPLOY.md.
#   2. OSS forks — the verifier is designed to be extractable to a
#      standalone repo (see verifier/package.json description). This file
#      is the canonical shape of its environment-config surface.

# --- Runtime ------------------------------------------------------------

# TCP port to bind Fastify to. Cloud Run sets PORT=8080 by default; the
# verifier reads PORT directly so it Just Works without further config.
PORT=8080

# Production vs dev. Production sets this to "production" in the Docker
# image ENV (image-baked, not Cloud Run env). Dev leaves it unset →
# pino-pretty logger + Play Integrity lenient-mode warning suppressed.
NODE_ENV=production

# --- Auth + DB ----------------------------------------------------------

# Bearer secret shared with the verify-and-create-media edge function.
# Both sides timing-safe-compare on every /verify request. Rotate via
# rolling restart on both sides at the same time.
#   Generate: openssl rand -base64 48
VERIFIER_SHARED_SECRET=

# Postgres connection string for the `verifier_readonly` role. Production
# targets PgBouncer (port 6543) for transaction-mode pooling. The role's
# password is set via `ALTER USER verifier_readonly WITH PASSWORD '...'`
# after running the Phase 1 migration (see verifier/DEPLOY.md).
DATABASE_URL=postgres://verifier_readonly:CHANGE_ME@PROJECT_REF.pooler.supabase.com:6543/postgres

# --- SSRF defense -------------------------------------------------------
#
# The verifier fetches signed Storage URLs to read uploaded assets. Two
# independent layers gate which URLs it will fetch — both must pass.

# First layer: URL-shape regex. Must match your asset-storage signed-URL
# shape (typically Supabase Storage). Anchored to the start of the URL so
# loose substring matches are impossible.
ASSET_STORAGE_HOST_REGEX=^https://PROJECT_REF\.supabase\.co/storage/v1/object/sign/

# Second layer (authoritative): explicit host allowlist. Comma-separated,
# case-insensitive, NO scheme. Matched against `new URL(...).host` so
# userinfo / weird port parsing can't slip past.
ASSET_STORAGE_HOST_ALLOWLIST=PROJECT_REF.supabase.co

# --- Asset size ceiling -------------------------------------------------

# Optional. Max asset size (MiB) the verifier will fetch + buffer into
# memory for a /verify call, checked against content-length before the body
# is read. Defaults to 50 when unset.
#
# Keep this >= your asset-storage bucket's file_size_limit, else a legit
# upload whose size lands in the gap band passes Storage and then fails here
# as oversize. No programmatic cross-repo check — bump both together.
# Invalid / non-positive / above the 512 MiB sanity ceiling → startup error.
# MAX_ASSET_MIB=50

# --- Observability ------------------------------------------------------

# Optional. When unset, src/observability.ts skips Sentry init entirely.
# Useful for dry-run smoke tests and local prod-mode debugging.
SENTRY_DSN=

# --- Trust anchors ------------------------------------------------------

# Optional. Path to the trust-sources.yaml file. Default
# `./trust-sources.yaml` works for both image-baked deployments and local
# dev — only override if you're testing a non-standard layout.
# TRUST_SOURCES_PATH=/app/trust-sources.yaml

# --- Play Integrity (Android per-capture attestation) ------------------
#
# IMPORTANT: both vars or neither. loadConfig() rejects partial config
# (typo on one var → other left unset) at startup. Both unset = lenient
# mode (structural envelope check + nonce burn, JWS decode skipped). In
# production with NODE_ENV=production, both-unset triggers a WARNING log
# at startup (category: "play-integrity", mode: "lenient") — alert on it.
#
# Production runtime ALSO requires Application Default Credentials for
# the Google Cloud service account calling playintegrity.googleapis.com.
# On Cloud Run that's the runtime SA — it must live in the project named
# below (the one linked in Play Console); there is no IAM role to grant.
# No env var needed for credentials.

# Android package name as it appears in Play Console. Cross-checked
# against tokenPayloadExternal.requestDetails.requestPackageName by the
# verifier — mismatch is a tampered or cross-app token.
PLAY_INTEGRITY_PACKAGE_NAME=com.realreel.app

# Google Cloud project number (NOT project ID) for the project that issues
# Play Integrity tokens for this build. Numeric. Used as the path segment
# in https://playintegrity.googleapis.com/v1/<package>:decodeIntegrityToken
# and cross-checked against the value the Android module passes to
# StandardIntegrityManager at token-request time.
#
# MUST match the value of CLOUD_PROJECT_NUMBER hardcoded in
# modules/photo-attest/android/.../PhotoAttestModule.kt. The two sides
# refer to the same Google Cloud project — the Android side requests
# tokens against it, the verifier side decodes tokens against it. If
# they diverge, decode fails.
PLAY_INTEGRITY_CLOUD_PROJECT_NUMBER=

# --- Strict require-presence -------------------------------------------
#
# ⚠️ MOST SAFETY-CRITICAL SETTING. When lenient, the verifier accepts
# uploads carrying NO attestation. In production (NODE_ENV=production) this
# var MUST be set EXPLICITLY to either "true" (strict) or "false" (lenient
# by deliberate choice). If it is unset or any other value in production,
# loadConfig() THROWS at startup — fail-closed on ambiguity, so a forgotten
# env var or a shell typo can never silently boot production wide open.
# Outside production it is lenient-by-default when unset (local dev).
#
# ATTESTATION_REQUIRED=true closes the Phase 1a lenient gate on Stage 2
# (the upload). With it set:
#   - iOS-signed Stage 2 MUST carry org.realreel.app_attest.
#   - Android-signed Stage 2 MUST carry org.realreel.play_integrity.
#   Missing Stage 2 envelope → ATTESTATION_MISSING reject.
#
# Stage 1 (the capture manifest) is ALWAYS LENIENT, even in strict mode.
# This is intentional. The Android client deliberately skips Play Integrity
# at capture time entirely (instant captures, no online dependency at the
# shutter); Stage 1 manifests from Android never carry play_integrity.
# iOS Stage 1 normally carries app_attest (App Attest is offline-capable),
# but extreme offline edge cases (depleted challenge cache) may produce
# Stage 1 without an envelope too. The strict Stage 2 requirement closes
# the bypass surface in both cases — same enrolled device signs both
# stages, so Stage 2 strict proves the build's integrity at upload time.
# See verifier/DEPLOY.md "Why Stage 1 is always lenient" + the trust
# architecture doc's "Android Stage 1 skip" section for the threat-model
# walkthrough.
#
# When ATTESTATION_REQUIRED is "false" (or, outside production, unset or
# any non-"true" value), the legacy lenient gate applies to BOTH stages:
# validate-if-present, accept-if-absent. The lenient gate is what makes
# local dev possible — without it, every Android upload would require a
# fully working Play Integrity stack with real Google credentials.
#
# PRODUCTION: set EXPLICITLY to "true" or "false" (see the fail-closed note
# at the top of this block — an unset/ambiguous value throws at startup).
# For strict mode ("true"), PLAY_INTEGRITY_PACKAGE_NAME and
# PLAY_INTEGRITY_CLOUD_PROJECT_NUMBER above MUST also be set, otherwise
# loadConfig() throws at startup (can't require what you can't decode).
#
# LOCAL DEV: leave unset. The Makefile's `verifier-dev` target doesn't
# set it either; local captures from unmodified dev builds DO carry
# attestation envelopes (the app side hard-fails on missing config), so
# nonce burns still happen — only JWS decode is skipped.
ATTESTATION_REQUIRED=true
