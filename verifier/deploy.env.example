# Verifier deploy config — copy to verifier/deploy.env (gitignored) and fill in.
#
# Non-secret, environment-specific values only. The verifier's real secrets
# (DATABASE_URL, VERIFIER_SHARED_SECRET, SENTRY_DSN) live in Secret Manager and
# are preserved across deploys by `gcloud run deploy --image=…` — this file
# never holds a secret value.
#
# Consumed by verifier/scripts/deploy.sh and verifier/scripts/rollback.sh.

# Published, attested source image (built by
# .github/workflows/publish-verifier-image.yml on a `verifier-v<semver>` tag).
GHCR_IMAGE=ghcr.io/<org>/realreel-verifier

# GitHub repo holding the SLSA build-provenance attestation (for `gh attestation verify`).
ATTEST_REPO=<org>/realreel-c2pa

# Artifact Registry image Cloud Run pulls from (Cloud Run cannot pull GHCR
# directly, so deploy.sh copies GHCR -> here, preserving the digest).
#   <region>-docker.pkg.dev/<verifier-project>/<repo>/realreel-verifier
GAR_IMAGE=<region>-docker.pkg.dev/<verifier-project>/verifier/realreel-verifier

# Cloud Run target.
GCP_PROJECT=<verifier-hosting-project>
GCP_REGION=<region>
CLOUD_RUN_SERVICE=realreel-verifier

# Set to false only if `gh` provenance verification is unavailable in your
# environment (e.g. CI without gh). Defaults to true; verification failing
# aborts the deploy.
VERIFY_PROVENANCE=true
